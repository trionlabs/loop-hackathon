PRINCIPAL_HANDLE=
PRINCIPAL_TZ=America/Los_Angeles

ANTHROPIC_API_KEY=

XAI_API_KEY=

X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_SECRET=

NOTION_TOKEN=
NOTION_PARENT_PAGE_ID=

TG_BOT_TOKEN=
TG_CHAT_ID=

MAX_POSTS_PER_DAY=4
MAX_REPLIES_PER_DAY=6

# shared secret between the runner and the write-server (generate locally:
# openssl rand -hex 32). Behind Pomerium this is the service-account JWT.
WRITEGUARD_TOKEN=
# write-server url the runner posts through, or the Pomerium route url
WRITEGUARD_URL=http://localhost:8787/mcp

# ports (optional, defaults shown)
PORT=3000
WRITE_SERVER_PORT=8787
UI_PORT=4000
