PRINCIPAL_HANDLE=
PRINCIPAL_TZ=America/Los_Angeles

# akash ml - the agent brain (open-model inference, openai compatible)
AKASHML_API_KEY=
AKASHML_BASE_URL=https://api.akashml.com/v1
AKASHML_MODEL=deepseek-ai/DeepSeek-V4-Flash

# akash cloud deployment api token (ops, not app runtime)
AKASH_DEPLOY_KEY=

# xai grok - x sensing (x_search, web_search)
XAI_API_KEY=

# x api v2, own account, oauth 1.0a (4 keys from the developer portal)
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_SECRET=

# notion (visible memory)
NOTION_TOKEN=
NOTION_PARENT_PAGE_ID=

# telegram (approval surface)
TG_BOT_TOKEN=
TG_CHAT_ID=

# shared secret between the runner and the write-server (generate locally:
# openssl rand -hex 32). Behind Pomerium this is the service-account JWT.
WRITEGUARD_TOKEN=
# write-server route the runner posts through (or the Pomerium route url)
WRITEGUARD_URL=http://localhost:8787/post

# pomerium zero (write-guard proxy). Token bootstraps the container; routes and
# policies are configured in the Pomerium Zero console.
POMERIUM_ZERO_TOKEN=
POMERIUM_ZERO_DOMAIN=

# guardrail limits
MAX_POSTS_PER_DAY=4
MAX_REPLIES_PER_DAY=6

# ports (optional, defaults shown)
PORT=3000
WRITE_SERVER_PORT=8787
UI_PORT=4000
